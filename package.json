{
  "name": "acode-devtoolkit",
  "version": "0.11.0",
  "private": true,
  "description": "A powerful developer toolkit plugin for Acode editor",
  "type": "module",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rishav7324/acode-devtoolkit.git"
  },
  "author": "Rishav Raj",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "html-tag-js": "^2.4.15"
  },
  "devDependencies": {
    "acode-plugin-types": "^1.12.6",
    "esbuild": "^0.25.8",
    "eslint": "^8.57.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "vitest": "^3.1.1"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs --serve",
    "build": "node esbuild.config.mjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate.mjs",
    "quality": "node scripts/quality-gate.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "node scripts/validate.mjs",
    "verify": "npm run lint && npm run typecheck && npm run validate && npm run build && npm run quality"
  },
  "browserslist": "cover 100%,not android < 5"
}
